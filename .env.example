# ─────────────────────────────────────────────────────────────────────────────
# CapScribe environment configuration
# Copy to `.env` and fill in. Never commit your real .env.
# ─────────────────────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development
PORT=3001
LOG_LEVEL=info

# Hedera network: testnet | mainnet
HEDERA_NETWORK=testnet

# Operator account — signs the HCS proof-of-completion via the Hedera Agent Kit.
# Get a free testnet account + key at https://portal.hedera.com/dashboard
HEDERA_ACCOUNT_ID=0.0.xxxxxxx
HEDERA_PRIVATE_KEY=302e0201...   # ECDSA or ED25519, hex or DER

# Account that receives x402 payments. Defaults to HEDERA_ACCOUNT_ID if unset.
PAYMENT_RECEIVER=0.0.xxxxxxx

# x402 facilitator (blocky402). FEE_PAYER is the facilitator's fee-payer account.
FACILITATOR_URL=https://api.testnet.blocky402.com
FEE_PAYER=0.0.7162784

# Optional: pin a pre-created HCS proof topic. If unset, the server (or
# `npm run setup:topic`) creates one on first run and caches it in .data/.
# HCS_TOPIC_ID=0.0.xxxxxxx

# Anthropic — powers the agent analysis.
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# WalletConnect / Reown project id (browser wallet connect).
# Create one free at https://dashboard.reown.com
WALLETCONNECT_PROJECT_ID=

# Allow a wallet-free "demo run" path (testnet/dev only — never on mainnet).
DEMO_BYPASS=false

# Where the JSON receipt store + cached topic live.
DATA_DIR=.data
