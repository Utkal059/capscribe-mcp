{
  "name": "capscribe-mcp",
  "version": "1.0.0",
  "description": "CapScribe — pay-to-run AI agent marketplace on Hedera (x402 payments, MCP/Agent Kit, HCS proof-of-completion).",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "ts-node src/server.ts",
    "dev:web": "npm --prefix web run dev",
    "build:server": "tsc",
    "build:web": "npm --prefix web install && npm --prefix web run build",
    "build": "npm run build:web && npm run build:server",
    "start": "node dist/server.js",
    "setup:topic": "ts-node src/scripts/setupTopic.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@hashgraph/sdk": "^2.81.0",
    "@x402/hedera": "^2.13.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.1",
    "hedera-agent-kit": "^3.8.2",
    "nanoid": "^3.3.12",
    "pino": "^9.14.0",
    "pino-pretty": "^13.1.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0",
    "vitest": "^2.1.9"
  }
}
